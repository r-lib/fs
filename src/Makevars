UNAME := $(shell uname)

PKG_LIBS = $(shell pkg-config --libs libuv) -pthread

SOURCES = $(wildcard *.cc unix/*.cc)
OBJECTS = $(SOURCES:.cc=.o)

ifeq ($(UNAME), FreeBSD)
PKG_LIBS += -lkvm
endif
ifeq ($(UNAME), OpenBSD)
PKG_LIBS += -lkvm
endif
ifeq ($(UNAME), NetBSD)
PKG_LIBS += -lkvm
endif
ifneq ($(filter $(UNAME), Linux AIX OS400),)
OBJECTS +=  bsd/setmode.o bsd/strmode.o bsd/reallocarray.o
endif


PKG_CFLAGS = $(C_VISIBILITY)
PKG_CPPFLAGS = $(shell pkg-config --cflags libuv) -I. -pthread

